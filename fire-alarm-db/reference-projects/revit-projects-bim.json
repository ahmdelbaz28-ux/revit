      "LOD100": {
        "description": "Conceptual - Approximate geometry",
        "fire_alarm_info": "Generic symbols, no specific equipment"
      },
      "LOD200": {
        "description": "Schematic Design - Generic systems",
        "fire_alarm_info": "Generic families, approximate locations"
      },
      "LOD300": {
        "description": "Design Development - Specific systems",
        "fire_alarm_info": "Specific families, exact locations, preliminary scheduling"
      },
      "LOD350": {
        "description": "Construction Documents",
        "fire_alarm_info": "Detailed families, coordination, detailed scheduling"
      },
      "LOD400": {
        "description": "Fabrication - Detailed for fabrication",
        "fire_alarm_info": "Fabrication-level families, installation-ready"
      }
    }
  },
