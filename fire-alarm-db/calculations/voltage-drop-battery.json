  "voltage_drop": {
    "formula": {
      "name": "DC Voltage Drop (two-wire circuit)",
      "formula": "Vdrop = (2 × I × R × L) / 1000",
      "variables": {
        "Vdrop": "Voltage drop in volts (V)",
        "I": "Total circuit current in amps (A)",
        "R": "Wire resistance per 1000 ft (Ω/kft)",
        "L": "One-way wire length in feet (ft)",
        "2": "Factor for two conductors (out and return)"
      },
      "metric_formula": "Vdrop = (2 × I × ρ × L) / A",
      "metric_variables": {
        "Vdrop": "Voltage drop in volts",
        "I": "Current in amps",
        "ρ": "Resistivity of copper = 0.0175 Ω·mm²/m at 20°C",
        "L": "One-way wire length in meters",
        "A": "Cross-sectional area of conductor in mm²"
      },
      "voltage_at_device": "Vdevice = Vpanel - Vdrop",
      "acceptance_criteria": {
        "voltage_at_farthest_device": "≥ 20VDC (recommended) / ≥ 16VDC (absolute minimum)",
        "voltage_drop_percentage": "≤ 10% of nominal voltage (24V × 0.10 = 2.4V max drop)",
        "notes": "Most manufacturers specify minimum operating voltage — always check datasheet"
      }
    },

