  "voltageDropFormula": {
    "basic": {
      "formula": "VD = (2 × L × I × K) / CM",
      "variables": {
        "VD": "Voltage drop (volts)",
        "L": "One-way length (feet)",
        "I": "Current (amps)",
        "K": "Resistance (ohms per 1000 ft)",
        "CM": "Wire circular mils"
      }
    },
    "example_calculation": {
      "wire": "14 AWG",
      "length_ft": 200,
      "current_amps": 2.0,
      "resistance_ohms_1000ft": 2.5,
      "circular_mils": 4110,
      "calculation": "VD = (2 × 200 × 2.0 × 2.5) / 4110",
      "voltage_drop_volts": 2.44,
      "acceptable": "Yes (< 10% of 24V = 2.4V)"
    }
  },
