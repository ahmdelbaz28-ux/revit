  "fire_command_center": {
    "requirements": {
      "size_min": {
        "sqft": 100,
        "meters": 9.3
      },
      "located": "PROTECTED_AREA",
      "equipment": [
        "Main fire alarm control panel",
        "Emergency voice system",
        "Fire department connection",
        "Building schematic display",
        "Radio system",
        "Telephone",
        "Emergency generator controls",
        "Elevator controls",
        "HVAC controls"
      ],
      "required_for": [
        "HIGH_RISE",
        "LARGE_AREA_OVER_50000_SQFT",
        "MULTI_BUILDING",
        "HEALTH_CARE"
      ],
      "code_reference": "NFPA 101 11.8.5, NFPA 72 21.2.1"
    }
  },
  "evacuation_procedures": {
    "phased_evacuation": {
      "enabled_for": ["HIGH_RISE", "HEALTH_CARE"],
      "phases": [
        {
          "phase": 1,
          "notify": "ALARM_IN_ZONE_ONLY",
          "action": "EVACUATE_AFFECTED_FLOOR"
        },
        {
          "phase": 2,
          "notify": "ADJACENT_FLOORS",
          "action": "PREPARE_TO_EVACUATE"
        },
        {
          "phase": 3,
          "notify": "COMPLETE_BUILDING",
          "action": "FULL_EVACUATION"
        }
      ]
    },
    "assembly_areas": {
      "outdoor": {
        "min_distance_ft": 100,
        "unit": "FROM_BUILDING"
      },
      "indoor": {
        "rated_area": "2_HOUR_FIRE_RATED",
        "ventilation": "REQUIRED"
      }
    }
  }
