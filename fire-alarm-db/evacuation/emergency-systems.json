  "voice_alarm_systems": {
    "requirements": {
      "minimum_for": [
        "HIGH_RISE_OVER_75FT",
        "ASSEMBLY_OVER_1000",
        "HEALTH_CARE_I1_I2",
        "EDUCATIONAL_OVER_300"
      ],
      "db_requirements": {
        "sleeping_area": 70,
        "general_area": 85,
        "loud_area": 90,
        "unit": "dBA"
      }
    },
    "system_types": [
      {
        "id": "VOICE_BASIC",
        "type": "Basic Voice System",
        "description": "Pre-recorded messages",
        "zones": 4,
        "amplifier Watts": 25,
        "typical_price_egp": 85000
      },
      {
        "id": "VOICE_ADVANCED",
        "type": "Advanced Voice System",
        "description": "Multiple messages, live paging",
        "zones": 32,
        "amplifier Watts": 100,
        "typical_price_egp": 180000
      },
      {
        "id": "VOICE_DIGITAL",
        "type": "Digital Voice System",
        "description": "Full addressable voice",
        "zones": 250,
        "amplifier Watts": 200,
        "typical_price_egp": 350000
      }
    ],
    "message_templates": [
      "May I have your attention. A fire emergency has been reported in the building. Please evacuate immediately using the nearest exit.",
      "This is a fire alarm. Do not use elevators. Please proceed to the nearest exit.",
      "Attention. This is an emergency. All personnel should exit the building immediately.",
      "All clear. The fire emergency has been handled. You may return to normal activities."
    ],
    "speaker_zoning": {
      "floor_by_floor": true,
      "zone_by_zone": true,
      "voice_command_all": true,
      "override_automode": true
    },
    "code_reference": "NFPA 72 24.4, NFPA 101 12.3.3"
  },
