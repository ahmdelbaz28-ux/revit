{
  "metadata": {
    "version": "2.0",
    "created": "2026-05-09",
    "author": "Fire Protection Engineering Consultant",
    "sources": ["NFPA 101 2024", "NFPA 72 2022", "Egyptian Code 2020", "International Best Practices"],
    "specialization": "HIGH_RISE_AND_SPECIAL_FACILITIES",
    "validation_status": "VERIFIED"
  },
  "highrise_buildings": {
    "definition": {
      "nfpa_threshold": ">75 feet (23 meters)",
      "egyptian_code_threshold": ">15 meters (7 floors approximately)",
      "classification": "HIGH_RISE"
    },
    "required_systems": [
      {
        "system": "FIRE_ALARM_CONTROL_PANEL",
        "requirement": "ADDRESSABLE with voice capability",
        "location": "FIRE_COMMAND_CENTER",
        "redundancy": "RECOMMENDED_SECONDARY_PANEL"
      },
      {
        "system": "FIRE_COMMAND_CENTER",
        "requirement": "MANDATORY",
        "size_sqft": 100,
        "features": [
          "Fire alarm control panel",
          "Emergency voice system",
          "Building schematic display",
          "Radio system",
          "Telephone",
          "Generator controls",
          "Elevator controls"
        ]
      },
      {
        "system": "VOICE_EVACUATION",
        "requirement": "MANDATORY",
        "phased_evacuation": true,
        "zones": "PER_FLOOR_MINIMUM"
      },
      {
        "system": "EMERGENCY_ELEVATORS",
        "requirement": "MANDATORY",
        "recall": "FIRE_SERVICE_MODE"
      },
      {
        "system": "FIREFIGHTER PHONE",
        "requirement": "MANDATORY",
        "locations": "EVERY_STAIRWELL"
      },
      {
        "system": "EMERGENCY POWER",
        "requirement": "MANDATORY",
        "duration_hours": 24
      }
    ],
    "stairwell_requirements": {
      "fire_rated": "2_HOUR_MINIMUM",
      "pressure": "POSITIVE_AIR",
      "intercom": "REQUIRED_AT_EVERY_5_FLOORS"
    },
    "phased_evacuation": {
      "phase_1": {
        "floors": "ALARM_FLOOR_AND_FLOOR_ABOVE",
        "action": "EVACUATE_TO_ASSEMBLY"
      },
      "phase_2": {
        "floors": "TWO_FLOORS_ABOVE_ALARM",
        "action": "PREPARE_TO_EVACUATE"
      },
      "phase_3": {
        "floors": "ALL_REMAINING",
        "action": "FULL_EVACUATION"
      }
    }
  },
  "power_plants": {
    "substation_classification": {
      "type": "GENERATION_PLANT",
      "risk_level": "CRITICAL",
      "hazards": ["TRANSFORMER_OIL", "CABLE_TUNNELS", "GENERATORS", "FUEL_STORAGE"]
    },
    "required_detection": {
      "transformer": {
        "type": "LINEAR_HEAT",
        "rating": "356F or 238F",
        "application": "OVERHEAD_TRANSFORMERS"
      },
      "cable_tunnel": {
        "type": "LINEAR_HEAT_or_ASPIRATING",
        "application": "CABLE_TRAY_ROUTING"
      },
      "generator_room": {
        "type": "SMOKE_PLUS_HEAT",
        "application": "GENERATOR_ENCLOSURE"
      },
      "fuel_storage": {
        "type": "FLAME_DETECTOR",
        "application": "FUEL_TANK_AREA"
      }
    },
    "suppression_systems": {
      "transformer": {
        "type": "CO2_or_FM200",
        "application": "OIL_FILLED_TRANSFORMERS",
        "activation": "AUTOMATIC_WITH_MANUAL"
      },
      "cable_tunnel": {
        "type": "WATER_MIST_or_FM200",
        "application": "CABLE_TUNNELS"
      },
      "generator": {
        "type": "FM200_or_DRY_PIPE",
        "application": "GENERATOR_ROOM"
      }
    },
    "special_requirements": [
      "Seismic protection for equipment",
      "Explosion proof detection in fuel areas",
      "Deluge system for transformer yards",
      "Foam system for fuel storage"
    ],
    "control_requirements": {
      "transformer_isolation": "AUTOMATIC_TRIP",
      "ventilation_shutdown": "AUTOMATIC",
      "fire_door_closure": "AUTOMATIC"
    }
  },
  "substations": {
    "voltage_levels": ["132kV", "66kV", "33kV", "11kV"],
    "risk_assessment": {
      "equipment": ["TRANSFORMERS", "CABLES", "SWITCHGEAR", "PROTECTION_RELAYS"],
      "fire_hazards": ["INSULATING_OIL", "CABLE_INSULATION", "DUST", "COMBUSTIBLE_STORED_ITEMS"]
