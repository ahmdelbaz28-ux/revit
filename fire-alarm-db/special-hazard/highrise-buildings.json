{
  "metadata": {
    "version": "2.0",
    "created": "2026-05-09",
    "author": "Fire Protection Engineering Consultant - High-Rise Specialist",
    "sources": ["NFPA 101 2024", "NFPA 72 2022", "Egyptian Code 2020", "High-Rise Building Standards"],
    "specialization": "HIGH_RISE_BUILDINGS_OVER_15_METERS",
    "validation_status": "VERIFIED"
  },
  "highrise_definitions": {
    "egyptian_code": {
      "threshold_meters": 15,
      "approximate_floors": 5,
      "reference": "Egyptian Fire Code Article 55"
    },
    "nfpa_101": {
      "threshold_feet": 75,
      "threshold_meters": 23,
      "reference": "NFPA 101 11.8.1"
    },
    "international": {
      "uae": "50 meters (Dubai Civil Defense)",
      "saudi": "23 meters",
      "uk": "30 meters"
    }
  },
  "classification_by_height": {
    "low_rise": {
      "range": "0-15 meters",
      "floors": "1-5 floors",
      "requirements": "Standard fire alarm system"
    },
    "mid_rise": {
      "range": "15-30 meters",
      "floors": "5-10 floors",
      "requirements": "Addressable system with voice recommended"
    },
    "high_rise": {
      "range": "30-60 meters",
      "floors": "10-20 floors",
      "requirements": "Voice evacuation mandatory, phased evacuation"
    },
    "tower": {
      "range": "60-100 meters",
      "floors": "20-33 floors",
      "requirements": "Full voice system, fire command center"
    },
    "super_tower": {
      "range": "100+ meters",
      "floors": "33+ floors",
      "requirements": "Advanced systems, redundant panels, special phased evacuation"
    }
  },
  "required_systems": {
    "fire_alarm_system": {
      "panel_type": "ADDRESSABLE_INTELLIGENT",
      "voice_evolution": "MANDATORY",
      "redundancy": "RECOMMENDED_SECONDARY_PANEL",
      "monitoring": "CENTRAL_STATION_MANDATORY"
    },
    "fire_command_center": {
      "location": "LOBBY_NEAR_MAIN_ENTRANCE",
      "size_sqft": 100,
      "features": [
        "Fire alarm control panel",
        "Voice evacuation panel",
        "Building fire alarm schematic",
        "Fire department telephone",
        "Emergency generator controls",
        "Elevator controls",
        "HVAC controls",
        "Public address system controls",
        "Radio system",
        "Building life safety systems overview"
      ]
    },
    "voice_evacuation_system": {
      "type": "DIGITAL_VOICE",
      "zones": "MINIMUM_ONE_PER_5_FLOORS",
      "phased_evacuation": true,
      "messages": [
        "FIRE_ALARM_MESSAGE",
        "EVACUATE_MESSAGE",
        "ALL_CLEAR_MESSAGE"
      ],
      "backup": "BATTERY_24HR_MIN"
    },
    "emergency_power": {
      "generator": "MANDATORY",
      "battery_backup": "24_HOURS_MINIMUM",
      "elevator_power": "REQUIRED",
      "fire_pump_power": "REQUIRED_SEPARATE"
    }
  },
  "evacuation_systems": {
    "phased_evacuation": {
      "enabled": true,
      "phases": [
        {
          "phase": 1,
          "trigger": "ALARM_ON_ANY_FLOOR",
          "notify": "ALARM_FLOOR + FLOOR_ABOVE + FLOOR_BELOW",
          "action": "EVACUATE_TO_STAIRS",
          "message": "FIRE_ALARM_IN_BUILDING_PLEASE_EVACUATE"
        },
        {
          "phase": 2,
          "trigger": "ALARM_SPREADS_OR_FIREFIGHTER_COMMAND",
          "notify": "TWO_FLOORS_ABOVE_ALARM",
          "action": "PREPARE_TO_EVACUATE"
        },
        {
          "phase": 3,
          "trigger": "FIREFIGHTER_COMMAND_OR_SECOND_ALARM",
          "notify": "ENTIRE_BUILDING",
          "action": "FULL_EVACUATION"
        }
      ]
    },
    "stairwell_pressurization": {
      "required": true,
      "pressure_difference": "0.1 INCH_WG_MIN",
      "airflow": "2500 CFM_PER_STAIRWELL",
      "activation": "AUTOMATIC_ON_ALARM"
    },
    "refuge_areas": {
      "required_for": "FLOORS_OVER_150FT",
      "location": "EVERY_10_FLOORS",
      "size": "30_SQFT_PER_OCCUPANT_MIN",
      "communication": "EMERGENCY_PHONE_REQUIRED"
    }
  },
  "elevator_requirements": {
    "fire_service_elevators": {
      "required_for": "FLOORS_OVER_75FT",
      "quantity": "MINIMUM_1_PER_ZONE",
      "recall": "AUTOMATIC_TO_LOBBY",
      "firefighter_service": "FIRE_SERVICE_MODE",
      "emergency_power": "REQUIRED"
    },
    "passenger_elevators": {
      "recall": "AUTOMATIC_ON_ALARM",
      "go_to": "LOBBY_OR_ALTERNATE_SAFE_FLOOR",
      "firefighter_service": "FIRE_SERVICE_MODE_OVERRIDE"
    }
  },
  "detection_zoning": {
    "floor_zoning": {
      "minimum": "ONE_ZONE_PER_FLOOR",
      "recommended": "ONE_ZONE_PER_10000_SQFT"
    },
    "zone_types": [
      {"zone": "GUEST_ROOMS", "for": "HOTEL"},
      {"zone": "OFFICE_FLOOR", "for": "COMMERCIAL"},
      {"zone": "RESIDENTIAL_FLOOR", "for": "RESIDENTIAL"},
      {"zone": "RETAIL_FLOOR", "for": "MALL"},
      {"zone": "MECHANICAL_FLOOR", "for": "ALL"}
    ],
    "common_areas": {
      "zones": ["LOBBY", "CORRIDORS", "STAIRWELLS", "ELEVATOR_MACHINE"],
      "priority": "HIGH"
    }
  },
  "device_requirements": {
    "detectors": {
      "guest_rooms": "1_PER_ROOM",
      "corridors": "PER_COVERAGE_2500_SQFT",
      "mechanical": "HEAT_DETECTORS_PREFERRED"
    },
    "manual_stations": {
      "locations": [
        "EVERY_EXIT_FROM_STAIRWELL",
        "EVERY_ELEVATOR_LOBBY",
        "MAIN_LOBBY",
        "EVERY_100FT_IN_CORRIDOR"
      ],
      "quantity_minimum": "2_PER_FLOOR"
    },
    "notification": {
      "corridors": "STROBE_PLUS_HORN",
      "rooms": "STROBE",
      "stairwells": "HORN",
      "db_level": "85_DBA_MIN"
    }
  },
  "fire_command_center_details": {
    "equipment": [
      {
        "item": "Fire alarm control panel",
        "location": "MAIN_DESK"
      },
      {
        "item": "Voice evacuation panel",
        "location": "MAIN_DESK"
      },
      {
        "item": "Building schematic display",
        "location": "WALL_MOUNTED"
      },
      {
        "item": "Fire department phone",
        "location": "DEDICATED_LINE"
      },
      {
        "item": "Building radio",
        "location": "HANDHELD_BASE"
      },
      {
        "item": "Generator status panel",
        "location": "MONITOR"
      },
      {
        "item": "Elevator controls",
        "location": "CONTROL_PANEL"
      },
      {
        "item": "HVAC controls",
        "location": "OVERRIDE_PANEL"
      },
      {
        "item": "Public address console",
        "location": "MICROPHONE_STATION"
      },
      {
        "item": "Emergency power status",
        "location": "MONITOR"
      }
    ]
  },
  "power_requirements": {
    "primary_power": {
      "source": "UTILITY_COMPANY",
      "capacity": "DESIGN_LOAD_125%"
    },
    "emergency_power": {
      "generator": {
        "fuel": "DIESEL_PREFERRED",
        "run_time": "24_HOURS_MIN",
        "autostart": "AUTOMATIC_ON_POWER_FAILURE"
      },
      "batteries": {
        "capacity": "24_HOURS_STANDBY",
        "alarm_time": "15_MINUTES_MINIMUM"
      }
    }
  },
  "communication_requirements": {
    "central_station": {
      "required": true,
      "signal_types": [
        "FIRE_ALARM",
        "TROUBLE",
        "SUPERVISORY",
        "BATT_LOW"
      ],
      "response_time": "90_SECONDS_MAX"
    },
    "fire_department": {
      "connection": "DIRECT_LINE_OR_CENTRAL_STATION",
      "automatic_dispatch": "RECOMMENDED"
    }
  },
  "inspection_testing": {
    "frequency": "ANNUALLY_MINIMUM",
    "tests": [
      "FULL_SYSTEM_FUNCTIONAL_TEST",
      "VOICE_EVACUATION_TEST",
      "ELEVATOR_RECALL_TEST",
      "HVAC_INTEGRATION_TEST",
      "GENERATOR_TRANSFER_TEST",
      "CENTRAL_STATION_COMMUNICATION_TEST"
    ]
  },
  "documentation_required": [
    "As-built drawings",
    "Zone list",
    "Sequence of operations",
    "Equipment schedules",
    "Wiring diagrams",
    "Testing reports",
    "Maintenance logs",
    "Fire department connection info"
  ],
  "egyptian_specific_requirements": {
    "civil_defense_approval": {
      "required": true,
      "submittal": [
        "Fire alarm design drawings",
        "Equipment specifications",
        "Calculations",
        "Sequence of operations"
      ]
    },
    "local_codes": [
      "Egyptian Fire Protection Code 2020",
      "Civil Defense Requirements",
      "Ministry of Interior Standards"
    ]
  }
}