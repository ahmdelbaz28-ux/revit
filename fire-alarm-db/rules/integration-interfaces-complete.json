  "fire_alarm_system_types": {
    "conventional": {
      "name": "Conventional (Traditional)",
      "abbreviation": "Conv",
      "description": "Zone-based detection - one alarm per zone",
      "wiring": "2-wire per zone",
      "modules_compatible": ["ZONE_MONITOR", "CONTROL_RELAY", "DUAL_MONITOR"],
      "integration": "LIMITED - Basic contacts only",
      "pros": ["Lower cost", "Simple wiring", "Easy troubleshooting"],
      "cons": ["No specific location", "Limited devices", "No advanced features"]
    },
    "addressable": {
      "name": "Addressable (Intelligent)",
      "abbreviation": "Addr",
      "description": "Individual device addressing - precise location",
      "wiring": "SLC loop (2-wire daisy chain)",
      "modules_compatible": ["ALL_MODULE_TYPES"],
      "integration": "FULL - Multiple protocols",
      "pros": ["Precise location", "Advanced features", "Network capability"],
      "cons": ["Higher cost", "Complex programming", "Specialized training"]
    },
    "wireless": {
      "name": "Wireless Fire Alarm",
      "abbreviation": "Wireless",
      "description": "Radio frequency based detection",
      "wiring": "RF mesh network",
      "modules_compatible": ["WIRELESS_RELAY", "GATEWAY_MODULE"],
      "integration": "LIMITED - Gateway dependent",
      "pros": ["No wiring", "Historic buildings", "Quick install"],
      "cons": ["Battery maintenance", "Interference risk", "Higher cost"]
    }
  },
  "module_types": {
    "monitor_modules": {
      "description": "Input modules - monitor contacts from other systems",
      "types": [
        {
          "code": "MON-1",
          "name": "Single Monitor Module",
          "type": "MONITOR",
          "input": 1,
          "addressable": true,
          "description": "Monitors one dry contact circuit",
          "typical_use": ["Manual pull station backup", "Tamper switch", "Flow switch"],
          "wiring": "2 wires to contact"
        },
        {
          "code": "MON-4",
          "name": "4-Zone Monitor Module",
          "type": "MONITOR",
          "input": 4,
          "addressable": true,
          "description": "Monitors up to 4 conventional zones",
          "typical_use": ["Conventional panel interface", "Multiple dry contacts"],
          "wiring": "4 separate circuits"
        },
        {
          "code": "MON-DUAL",
          "name": "Dual Monitor Module",
          "type": "MONITOR",
          "input": 2,
          "addressable": true,
          "description": "Monitors two independent circuits",
          "typical_use": ["Sprinkler + Flow", "Two areas monitoring"],
          "wiring": "2 separate circuits"
        },
        {
          "code": "MON-ZONE",
          "name": "Zone Interface Module",
          "type": "MONITOR",
          "input": "Conventional zone",
          "addressable": true,
          "description": "Connects conventional detectors to addressable panel",
          "typical_use": ["Legacy system upgrade", "Conventional zone integration"],
          "wiring": "Conventional zone wiring"
        }
      ]
    },
    "control_modules": {
      "description": "Output modules - control other systems",
      "types": [
        {
          "code": "CTL-1",
          "name": "Single Control Module",
          "type": "CONTROL",
          "output": 1,
          "relay_type": "FORM_C",
          "rating": "5A_120VAC_or_28VDC",
          "addressable": true,
          "description": "Controls one output circuit",
          "typical_use": ["HVAC shutdown", "Door holder release", "Elevator recall"],
          "wiring": "2 wires to controlled device"
        },
        {
          "code": "CTL-DUAL",
          "name": "Dual Control Module",
          "type": "CONTROL",
          "output": 2,
          "relay_type": "FORM_C",
          "addressable": true,
          "description": "Two independent relay outputs",
          "typical_use": ["Multiple system control", "Redundant outputs"],
          "wiring": "2 circuits"
        },
        {
          "code": "CTL-POWER",
          "name": "Power Control Module",
          "type": "CONTROL",
          "output": 1,
          "rating": "10A_240VAC",
          "addressable": true,
          "description": "High current control",
          "typical_use": ["Large equipment shutdown", "Motor control"],
          "wiring": "Power wiring"
        }
      ]
    },
    "isolator_modules": {
      "description": "Fault isolation - protect loop from shorts",
      "types": [
        {
          "code": "ISO-1",
          "name": "Single Isolator",
          "type": "ISOLATOR",
          "circuits": 1,
          "addressable": true,
          "description": "Isolates single fault section",
          "typical_use": ["Loop protection", "Section isolation"],
          "wiring": "Inline with SLC loop"
        },
        {
          "code": "ISO-6",
          "name": "6-Circuit Isolator",
          "type": "ISOLATOR",
          "circuits": 6,
          "addressable": true,
          "description": "Isolates up to 6 branches",
          "typical_use": ["Multi-zone protection"],
          "wiring": "Branch isolation"
        }
      ]
    },
    "relay_modules": {
      "description": "General purpose relays",
      "types": [
        {
          "code": "RLY-1",
          "name": "Single Relay Module",
          "type": "RELAY",
          "contacts": "FORM_C",
          "rating": "5A_120VAC",
          "addressable": false,
          "description": "Standalone relay",
          "typical_use": ["Basic on/off control"],
          "wiring": "120V control circuit"
        },
        {
          "code": "RLY-EXP",
          "name": "Expansion Relay",
          "type": "RELAY",
          "contacts": "FORM_C",
          "rating": "10A",
          "addressable": true,
          "description": "High capacity relay",
          "typical_use": ["HVAC", "Pump control"]
        }
      ]
    },
    "special_modules": {
      "description": "Specialized integration modules",
      "types": [
        {
          "code": "FIB-INT",
          "name": "Fiber Interface",
          "type": "INTERFACE",
          "description": "Fiber optic SLC connection",
          "typical_use": ["Long distance", "Industrial environments"],
          "protocol": "Fiber to copper conversion"
        },
        {
          "code": "NET-MOD",
          "name": "Network Module",
          "type": "NETWORK",
          "description": "Panel to network connection",
          "typical_use": ["Multiple panel networking"],
          "protocol": "TCP/IP or proprietary"
        },
        {
          "code": "BAC-MOD",
          "name": "BACnet Interface",
          "type": "PROTOCOL",
          "description": "Building automation connection",
          "typical_use": ["BMS integration"],
          "protocol": "BACnet MS/TP"
        },
        {
          "code": "MOD-IP",
          "name": "IP Communicator",
          "type": "COMMUNICATION",
          "description": "IP-based central station communication",
          "typical_use": ["Monitoring", "Remote access"],
          "protocol": "IP/GSM"
        }
      ]
    }
  },
