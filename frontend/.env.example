# Frontend Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit real API keys to the repository.

# API base URL — uses Vite dev server proxy in development.
# For production, point at the deployed backend (Hugging Face Space).
VITE_API_URL=https://your-project.hf.space/api/v1

# FireAI API Key (required in production for mutating requests)
# SECURITY: This key is embedded in the client bundle — use a key with
# minimal permissions (VIEWER role recommended for frontend).
# V243: Best practice is to NOT set this and rely on the HttpOnly session
# cookie set by POST /auth/login. Only set this if you need server-side
# rendering or headless builds that can't use cookies.
VITE_FIREAI_API_KEY=

# Supabase (used by frontend data services for auth + REST data)
# V243 SECURITY: Replace with YOUR project's URL and anon key.
# The anon key is public-by-design (safe for the client bundle) but should
# be YOUR project's key, not a shared one.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Feature flags (optional)
# VITE_ENABLE_VOICE_CONTROL=true
# VITE_ENABLE_3D_VIEWER=true
