# Frontend Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit real API keys to the repository.

# API base URL (default: /api/v1 — uses Vite dev server proxy in development)
VITE_API_URL=/api/v1

# FireAI API Key (required in production for mutating requests)
# In development, you can leave this empty and set it via the Settings page.
# In production, set this at build time: VITE_FIREAI_API_KEY=your_key npm run build
# SECURITY: This key is embedded in the client bundle — use a key with
# minimal permissions (VIEWER role recommended for frontend).
VITE_FIREAI_API_KEY=

# Feature flags (optional)
# VITE_ENABLE_VOICE_CONTROL=true
# VITE_ENABLE_3D_VIEWER=true
