# FireAI Frontend - Environment Variables
# NEVER commit actual .env files to version control!
# Copy this file to .env and fill in the values.

# ── Application ──────────────────────────────────────────────
VITE_APP_NAME=FireAI
VITE_APP_ENV=development

# ── API Configuration ────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# ── Sentry Error Tracking (optional) ────────────────────────
# Leave empty to disable Sentry
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# ── Dev Server (optional) ───────────────────────────────────
# Override dev server host (default: localhost)
# Set to 0.0.0.0 ONLY in Docker/container environments
VITE_DEV_HOST=localhost

# Comma-separated list of allowed hosts for Vite dev server
VITE_ALLOWED_HOSTS=localhost

# ── Feature Flags ───────────────────────────────────────────
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_3D_VIEWER=true
