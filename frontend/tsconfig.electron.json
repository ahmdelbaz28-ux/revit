{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "electron/compiled",
    "rootDir": "electron",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["electron/main.ts", "electron/preload.ts"],
  "exclude": ["node_modules", "dist"]
}
