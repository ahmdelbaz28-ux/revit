{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "ESNext",

    /* Type Safety — strict mode enabled (P2.6)
     * Gradually enabling strict flags. Currently enabled:
     * - strict: true (covers strictNullChecks, strictFunctionTypes, etc.)
     * - noFallthroughCasesInSwitch: true
     * - noImplicitOverride: true (safe to enable — only requires `override` keyword)
     *
     * TODO: Enable these after fixing pre-existing violations:
     * - noUnusedLocals (many unused imports in pages/)
     * - noUnusedParameters (many unused event handlers)
     * - noUncheckedIndexedAccess (would break many array accesses)
     */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    /* skipLibCheck kept true for Vite ecosystem compatibility
     * (many @types packages have cross-version conflicts) */
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    "esModuleInterop": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "mockupPreviewPlugin.ts", "vite.config.ts"],
  "exclude": ["node_modules", "build", "dist"]
}
