	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Pre-request Script",
					"// Set any variables or configurations before the request"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Test Script",
					"// Validate response and capture data",
					"pm.test(\"Status code is 200\", function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"",
					"pm.test(\"Response time is less than 500ms\", function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(500);",
					"});",
					"",
					"// Capture response time for reporting",
					"pm.environment.set(\"response_time\", pm.response.responseTime);",
					"",
					"// Capture response data for reporting",
					"pm.environment.set(\"response_body\", pm.response.text());"
				]
			}
		}
