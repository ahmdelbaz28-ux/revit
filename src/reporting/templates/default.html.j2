{# =====================================================================
   FireSafetyGenius — Default HTML Report Template
   =====================================================================
   This template is FULLY EDITABLE. Copy it to a project directory with
   `fsg templates export <dir>` and customize logos, colours, sections.

   All variables documented in `reporting.comprehensive_report.list_template_variables()`
   ===================================================================== #}
<!doctype html>
<html lang="en" dir="ltr">
<head>
<meta charset="utf-8">
<title>{{ r.project.name }} — Fire Safety Assessment</title>
<style>
  :root{--ink:#0f1419;--mut:#5b6470;--accent:#c0392b;--ok:#27ae60;
        --warn:#e67e22;--bg:#fff;--card:#f7f8fa;--border:#dde2e8}
  *{box-sizing:border-box}
  body{font:13px/1.55 -apple-system,'Segoe UI',Roboto,'Helvetica Neue',sans-serif;
       background:var(--bg);color:var(--ink);margin:0;padding:32px;max-width:1100px}
  h1{font-size:28px;margin:0 0 4px;color:var(--ink)}
  h2{font-size:18px;margin:32px 0 8px;border-bottom:2px solid var(--accent);
     padding-bottom:6px;color:var(--ink)}
  h3{font-size:14px;margin:20px 0 6px;color:var(--mut);text-transform:uppercase;
     letter-spacing:.05em}
  .cover{padding:24px;background:linear-gradient(135deg,var(--ink) 0%,#2c3e50 100%);
         color:#fff;border-radius:8px;margin-bottom:24px}
  .cover h1{color:#fff}
  .cover .sub{opacity:.85;font-size:14px}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
  .card{background:var(--card);border:1px solid var(--border);border-radius:6px;
        padding:12px 16px}
  .k{font-size:11px;color:var(--mut);text-transform:uppercase;letter-spacing:.05em}
  .v{font-size:18px;font-weight:600;margin-top:4px}
  table{width:100%;border-collapse:collapse;margin:8px 0;font-size:12px}
  th,td{padding:8px 10px;text-align:left;border-bottom:1px solid var(--border);
        vertical-align:top}
  th{background:var(--card);font-weight:600;color:var(--mut);
     text-transform:uppercase;font-size:10px;letter-spacing:.05em}
  .sev{display:inline-block;padding:2px 8px;border-radius:3px;font-size:10px;
       font-weight:700;text-transform:uppercase;color:#fff}
  .sev.critical{background:var(--accent)} .sev.major{background:var(--warn)}
  .sev.minor{background:#f1c40f;color:#000}.sev.advisory{background:#3498db}
  .sev.info{background:#7f8c8d}
  .lim{background:#fdf5e6;border-left:4px solid var(--warn);padding:12px 16px;
       margin:8px 0;border-radius:0 4px 4px 0}
  .integrity{background:var(--card);border:1px dashed var(--border);
             padding:14px;font-family:'SF Mono',Menlo,monospace;font-size:11px;
             border-radius:6px;word-break:break-all}
  .hash{color:var(--accent);font-weight:600}
  .sig-box{border:2px solid var(--ink);padding:24px;margin-top:32px;
           border-radius:6px;background:#fafbfc}
  .sig-line{border-bottom:1px solid var(--ink);min-height:22px;margin:18px 0 4px}
  .stamp{display:inline-block;border:3px double var(--accent);padding:14px 28px;
         color:var(--accent);font-weight:700;letter-spacing:.1em;transform:rotate(-3deg);
         margin-top:14px}
  footer{margin-top:48px;padding-top:18px;border-top:1px solid var(--border);
         color:var(--mut);font-size:11px;text-align:center}
  .toc a{color:var(--ink);text-decoration:none}
  .toc a:hover{color:var(--accent)}
  @media print{.cover{background:none;color:#000;border:1px solid #000}
              body{padding:0;font-size:11px} h2{page-break-after:avoid}
              table{page-break-inside:avoid}}
</style>
</head>
<body>

{# ─── COVER ───────────────────────────────────────────────────── #}
<div class="cover">
  <h1>{{ r.project.name|e }}</h1>
  <div class="sub">Fire Safety Engineering Assessment Report</div>
  <div class="sub" style="margin-top:14px">
    Generated by <strong>{{ r.issuer }}</strong> v{{ r.software }} ·
    Issued {{ r.integrity.issued_at_utc }}
  </div>
</div>

{# ─── 1. PROJECT IDENTIFICATION ───────────────────────────────── #}
<h2>1. Project Identification</h2>
<table>
  <tr><th style="width:30%">Project</th><td>{{ r.project.name|e }}</td></tr>
  <tr><th>Address</th><td>{{ r.project.address|e }}</td></tr>
  <tr><th>Owner</th><td>{{ r.project.owner|e }}</td></tr>
  <tr><th>Consultant</th><td>{{ r.project.consultant|e }}</td></tr>
  <tr><th>Jurisdiction</th><td>{{ r.project.jurisdiction|e }}</td></tr>
  <tr><th>Occupancy</th><td>{{ r.project.occupancy|e }}</td></tr>
  <tr><th>Sprinklered</th><td>{{ "Yes" if r.project.sprinklered else "No" }}</td></tr>
  <tr><th>Source file</th><td><code>{{ r.source_file.name|e }}</code>
    ({{ r.source_file.type }})</td></tr>
  <tr><th>File SHA-256</th>
    <td style="font-family:monospace;font-size:10px">{{ r.source_file.sha256 }}</td></tr>
</table>

{# ─── 2. EXECUTIVE SUMMARY ────────────────────────────────────── #}
<h2>2. Executive Summary</h2>
<div class="grid">
  <div class="card"><div class="k">Total Elements</div>
    <div class="v">{{ r.elements|length }}</div></div>
  <div class="card"><div class="k">Identified Symbols</div>
    <div class="v">{{ r.counts.values()|sum }}</div></div>
  <div class="card"><div class="k">Findings</div>
    <div class="v">{{ r.findings|length }}</div></div>
  <div class="card"><div class="k">Critical</div>
    <div class="v" style="color:var(--accent)">
      {{ r.findings|selectattr('severity','equalto','critical')|list|length }}
    </div></div>
  <div class="card"><div class="k">Major</div>
    <div class="v" style="color:var(--warn)">
      {{ r.findings|selectattr('severity','equalto','major')|list|length }}
    </div></div>
</div>

{% if r.reasoning and r.reasoning.conclusion %}
<h3>Verdict</h3>
<div class="card" style="border-left:4px solid
    {% if r.reasoning.severity=='pass' %}var(--ok)
    {% elif r.reasoning.severity=='fail' %}var(--accent)
    {% else %}var(--warn){% endif %}">
  <strong>{{ r.reasoning.conclusion|e }}</strong><br>
  <small>Confidence: {{ "%.0f"|format((r.reasoning.confidence or 0)*100) }}% · Status:
    <code>{{ r.reasoning.severity }}</code></small>
</div>
{% endif %}

{# ─── 3. METHODOLOGY ──────────────────────────────────────────── #}
<h2>3. Methodology — How This Analysis Was Performed</h2>
<table>
  <tr><th>#</th><th>Step</th><th>Algorithm</th><th>Tools / Notes</th></tr>
  {% for step in r.methodology %}
  <tr><td>{{ step.step }}</td><td><strong>{{ step.name }}</strong></td>
    <td>{{ step.algorithm }}</td>
    <td>{% if step.tools %}{{ step.tools|join(', ') }}{% endif %}
      {% if step.limitations %}<br><em style="color:var(--warn)">⚠ {{ step.limitations }}</em>{% endif %}
    </td></tr>
  {% endfor %}
</table>

{# ─── 4. CODE APPLICABILITY MATRIX ────────────────────────────── #}
<h2>4. Code Applicability Matrix</h2>
<table>
  <tr><th>Code</th><th>Edition</th><th>Applies</th><th>Scope</th></tr>
  {% for c in r.code_matrix %}
  <tr><td><strong>{{ c.code }}</strong></td><td>{{ c.edition }}</td>
    <td>{% if c.applies %}✓{% else %}—{% endif %}</td>
    <td>{{ c.scope }}</td></tr>
  {% endfor %}
</table>

{# ─── 5. CLASSIFIED ELEMENTS ──────────────────────────────────── #}
<h2>5. Classified Elements</h2>
<table>
  <tr><th>Symbol</th><th>Count</th></tr>
  {% for sym, n in r.counts|dictsort(by='value', reverse=true) %}
  <tr><td>{{ sym }}</td><td>{{ n }}</td></tr>
  {% endfor %}
</table>

{# ─── 6. FINDINGS ─────────────────────────────────────────────── #}
{% if r.findings %}
<h2>6. Compliance &amp; Safety Findings</h2>
<table>
  <tr><th>#</th><th>Severity</th><th>Code</th><th>Rule</th>
    <th>Finding</th><th>Recommendation</th><th>Hash</th></tr>
  {% for f in r.findings %}
  <tr>
    <td>{{ loop.index }}</td>
    <td><span class="sev {{ f.severity }}">{{ f.severity }}</span></td>
    <td>{{ f.code|e }}</td>
    <td>{{ f.rule|e }}</td>
    <td>{{ f.message|e }}<br>
        <small style="color:var(--mut)">{{ f.citation|e }}</small></td>
    <td>{{ f.recommendation|e }}</td>
    <td style="font-family:monospace;font-size:9px">{{ f.hash[:12] }}…</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

{# ─── 7. SCHEDULE RECONCILIATION ──────────────────────────────── #}
{% if r.reconciliation %}
<h2>7. Schedule Reconciliation (BoQ vs Drawing)</h2>
<table>
  <tr><th>Item</th><th>Scheduled</th><th>On drawing</th><th>Δ</th><th>Status</th></tr>
  {% for rec in r.reconciliation %}
  <tr><td>{{ rec.item|e }}</td><td>{{ rec.scheduled_qty }}</td>
    <td>{{ rec.actual_qty }}</td>
    <td>{{ "%+d"|format(rec.delta) }}</td>
    <td><span class="sev {% if rec.status=='match' %}info{% else %}major{% endif %}">
        {{ rec.status }}</span></td></tr>
  {% endfor %}
</table>
{% endif %}

{# ─── 8. ENGINEERING CALCULATIONS ─────────────────────────────── #}
{% if r.engineering %}
<h2>8. Engineering Calculations</h2>

  {% if r.engineering.panel_plan %}
  <h3>Panel placement (k-median optimization)</h3>
  <table>
    <tr><th>Panel</th><th>Position</th><th>Devices served</th>
        <th>Total cable</th><th>Worst run</th></tr>
    {% for p in r.engineering.panel_plan.panels %}
    <tr><td>{{ p.id }}</td>
      <td>({{ "%.1f"|format(p.position[0]) }}, {{ "%.1f"|format(p.position[1]) }})</td>
      <td>{{ p.device_count }}</td>
      <td>{{ "%.0f"|format(p.total_cable_m) }} m</td>
      <td>{{ "%.0f"|format(p.max_single_run_m) }} m</td></tr>
    {% endfor %}
  </table>
  <p><strong>Total cable estimate:</strong>
    {{ "%.0f"|format(r.engineering.panel_plan.total_cable_m) }} m</p>
  {% endif %}

  {% if r.engineering.loop_plan %}
  <h3>SLC loop design (TSP 2-opt)</h3>
  <table>
    <tr><th>Loop</th><th>Devices</th><th>Length</th><th>Class</th></tr>
    {% for l in r.engineering.loop_plan.loops %}
    <tr><td>{{ l.id }}</td><td>{{ l.order|length }}</td>
        <td>{{ l.total_length_m }} m</td>
        <td>{% if l.class_b %}B{% else %}A{% endif %}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  {% if r.engineering.voltage_drop %}
  <h3>Voltage drop (accurate per-segment)</h3>
  <p>Supply <strong>{{ r.engineering.voltage_drop.supply_v }} V</strong> →
     End <strong>{{ r.engineering.voltage_drop.end_voltage_v }} V</strong>
     ({{ r.engineering.voltage_drop.total_drop_v }} V drop)
     · AWG #{{ r.engineering.voltage_drop.awg }}
     · {% if r.engineering.voltage_drop.ok %}<span class="sev info">PASS</span>
        {% else %}<span class="sev critical">FAIL</span>{% endif %}
  </p>
  {% endif %}

  {% if r.engineering.smoke_sim %}
  <h3>Smoke simulation (NFPA 92 two-zone)</h3>
  <table>
    <tr><th>Room</th><th>Volume</th><th>Detect</th><th>Untenable</th>
        <th>Margin</th></tr>
    {% for sim in r.engineering.smoke_sim %}
    <tr><td>{{ sim.room }}</td><td>{{ sim.volume_m3 }} m³</td>
      <td>{{ sim.time_to_detect_s|default('—') }} s</td>
      <td>{{ sim.time_to_untenable_s|default('—') }} s</td>
      <td>{{ sim.safety_margin_s|default('—') }} s</td></tr>
    {% endfor %}
  </table>
  {% endif %}
{% endif %}

{# ─── 9. SELF-LEARNING LOG ────────────────────────────────────── #}
{% if r.learning %}
<h2>9. Self-Learning Outcome</h2>
<p>The system processed this file and updated its knowledge base
   <strong>autonomously</strong>:</p>
<table>
  <tr><th>Mechanism</th><th>Updates</th></tr>
  <tr><td>Layer co-occurrence (which symbols appear on which layers)</td>
      <td>{{ r.learning.cooccur_updates|default(0) }}</td></tr>
  <tr><td>Block-name aliases learned</td>
      <td>{{ r.learning.aliases_learned|default(0) }}</td></tr>
  <tr><td>Spacing distribution samples added</td>
      <td>{{ r.learning.spacing_updates|default(0) }}</td></tr>
  <tr><td>Legend pairs harvested (image+label)</td>
      <td>{{ r.learning.legend_pairs_learned|default(0) }}</td></tr>
  <tr><td>Unknown-symbol clusters (created / matched)</td>
      <td>{{ r.learning.clusters_created|default(0) }} /
          {{ r.learning.clusters_matched|default(0) }}</td></tr>
  <tr><td>Regex patterns proposed</td>
      <td>{{ r.learning.patterns_proposed|default(0) }}</td></tr>
  <tr><td>Calibration buckets updated</td>
      <td>{{ r.learning.calibration_updates|default(0) }}</td></tr>
</table>
{% endif %}

{# ─── 10. REASONING TRACE ─────────────────────────────────────── #}
{% if r.reasoning and r.reasoning.steps %}
<h2>10. Reasoning Trace (auditable step-by-step)</h2>
<table>
  <tr><th>Step</th><th>Description</th><th>Tool</th><th>Output</th></tr>
  {% for s in r.reasoning.steps %}
  <tr><td>{{ s.step }}</td><td>{{ s.description|e }}</td>
    <td><code>{{ s.tool }}</code></td>
    <td><code style="font-size:10px">{{ s.output|tojson|truncate(180) }}</code></td></tr>
  {% endfor %}
</table>
{% endif %}

{# ─── 11. HONEST LIMITATIONS ──────────────────────────────────── #}
<h2>11. Limitations of This Report (read carefully)</h2>
<div class="lim">
  <strong>This report makes no claim of infallibility.</strong> The cryptographic
  seal proves the report has not been altered since issuance — it does NOT
  prove the underlying analysis is free of error.
</div>
<ul>
  {% for L in r.limitations %}
  <li>{{ L }}</li>
  {% endfor %}
</ul>

{# ─── 12. REVIEWER SIGN-OFF ──────────────────────────────────── #}
<h2>12. Licensed Engineer Sign-Off</h2>
<div class="sig-box">
  <p>I have reviewed this automated analysis and the underlying drawings,
     and I accept professional responsibility for the design decisions
     reflected in this assessment.</p>

  <table style="margin-top:14px">
    <tr><th style="width:30%">Engineer Name</th>
        <td><div class="sig-line">{{ r.review_block.engineer_name|e }}</div></td></tr>
    <tr><th>License Number</th>
        <td><div class="sig-line">{{ r.review_block.license_no|e }}</div></td></tr>
    <tr><th>State / Jurisdiction</th>
        <td><div class="sig-line">{{ r.review_block.license_state|e }}</div></td></tr>
    <tr><th>Signature Date</th>
        <td><div class="sig-line">{{ r.review_block.signature_date|e }}</div></td></tr>
    <tr><th>Approval Status</th>
        <td><span class="sev {% if r.review_block.approval_status=='APPROVED' %}info
            {% elif r.review_block.approval_status=='REJECTED' %}critical
            {% else %}major{% endif %}">
            {{ r.review_block.approval_status }}</span></td></tr>
    <tr><th>Notes</th>
        <td>{{ r.review_block.approval_notes|e or '—' }}</td></tr>
  </table>

  {% if r.review_block.approval_status == 'APPROVED' %}
    <div class="stamp">ENGINEER APPROVED</div>
  {% endif %}
</div>

{# ─── 13. CRYPTOGRAPHIC INTEGRITY ─────────────────────────────── #}
<h2>13. Cryptographic Integrity</h2>
<div class="integrity">
  <div><strong>Schema:</strong> {{ r.integrity.schema_version }}</div>
  <div><strong>Issued:</strong> {{ r.integrity.issued_at_utc }} UTC</div>
  <div><strong>Issuer:</strong> {{ r.integrity.issuer }}</div>
  <div><strong>Software:</strong> {{ r.integrity.software }}</div>
  <div><strong>Chain root (SHA-256):</strong>
       <span class="hash">{{ r.integrity.chain_root }}</span></div>
  <div><strong>Signature algorithm:</strong> {{ r.integrity.signature_alg }}</div>
  {% if r.integrity.signature %}
  <div style="margin-top:8px"><strong>Signature:</strong>
    <span class="hash">{{ r.integrity.signature }}</span></div>
  <details style="margin-top:8px">
    <summary>Public key (verify with this)</summary>
    <pre style="font-size:10px;white-space:pre-wrap">{{ r.integrity.public_key_pem }}</pre>
  </details>
  {% endif %}
  <p style="margin-top:14px;color:var(--mut)">
    To verify this report:<br>
    <code>fsg verify-seal &lt;report.json&gt;</code>
  </p>
</div>

<footer>
  Generated by {{ r.issuer }} v{{ r.software }} ·
  {{ r.integrity.issued_at_utc }} UTC ·
  Chain root <code>{{ r.integrity.chain_root[:16] }}…</code><br>
  This automated analysis must be reviewed and signed by a licensed
  Professional Engineer before any code submission or construction.
</footer>

</body>
</html>
