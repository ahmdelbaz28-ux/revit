# FireAI Environment Configuration
FIREAI_ENV=development
FIREAI_API_KEY=your-64-char-hex-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///./db/digital_twin.db
DIGITAL_TWIN_DB_PATH=./db/digital_twin.db
UDM_DB_PATH=./db/udm_elements.db

# CORS (Development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Redis (for memory/cache features)
# REDIS_URL=redis://localhost:6379/0

# Kiro Proxy Configuration
KIRO_BASE_URL=http://localhost:8000
KIRO_API_KEY=your-kiro-proxy-key-here

# Claude Agent SDK
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=4096

# OpenHands
OPENHANDS_API_KEY=your-openhands-key-here
OPENHANDS_BASE_URL=http://localhost:3000
