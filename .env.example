# FireAI Environment Configuration
FIREAI_ENV=development
FIREAI_API_KEY=your-64-char-hex-key-here-change-in-production

# Database
# Local dev: SQLite (default)
DATABASE_URL=sqlite:///./db/digital_twin.db
DIGITAL_TWIN_DB_PATH=./db/digital_twin.db
UDM_DB_PATH=./db/udm_elements.db
# Production — STANDARD config (Supabase primary + Neon IPv4 fallback)
#   DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<ref>.supabase.co:5432/postgres?sslmode=require
#   NEON_DATABASE_URL=postgresql://bazspark_owner:<PASSWORD>@ep-xxx.c-9.us-east-1.aws.neon.tech/bazspark?sslmode=require
#
# The backend (backend/database.py::_init_postgres) tries DATABASE_URL first,
# then falls back to NEON_DATABASE_URL if the primary is unreachable
# (e.g. HF Spaces free tier cannot reach Supabase's IPv6-only endpoint).
# This makes both databases work together: Supabase stays as the standard
# primary; Neon is the automatic IPv4 fallback.
#
# Supabase REST integration (works over HTTPS regardless of IPv6):
#   SUPABASE_URL=https://<ref>.supabase.co
#   SUPABASE_ANON_KEY=<anon JWT>
#   SUPABASE_SERVICE_ROLE_KEY=<service_role JWT>

# CORS (Development) — must match backend/app.py env var name
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Redis (for memory/cache features)
# REDIS_URL=redis://localhost:6379/0

# Kiro Proxy Configuration
KIRO_BASE_URL=http://localhost:8000
KIRO_API_KEY=your-kiro-proxy-key-here

# Claude Agent SDK
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=4096

# OpenHands
OPENHANDS_API_KEY=your-openhands-key-here
OPENHANDS_BASE_URL=http://localhost:3000

# =============================================================================
# Cloud Services (required for E2E tests)
# =============================================================================

# Neo4j Aura
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-password>

# Qdrant Cloud
QDRANT_URL=https://<your-cluster>.cloud.qdrant.io:6333
QDRANT_API_KEY=<your-api-key>

# OpenAI (for Modal fallback)
OPENAI_API_KEY=sk-...

# Modal
MODAL_API_KEY=modal-...

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# NVIDIA API (V168 — OpenAI-compatible, 120+ models, no region block)
# Get key: https://build.nvidia.com/
# Default model: meta/llama-3.1-8b-instruct (verified working)
# Other models: meta/llama-3.3-70b-instruct, mistralai/mistral-large-2-instruct, etc.
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2