# FireAI Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === AI Provider Keys ===
# SECURITY: Never commit actual API keys. Use environment variables or a secrets manager.
OPENAI_API_KEY=
GEMINI_API_KEY=

# === AI Memory Configuration ===
# V106: Gemini is the PRIMARY AI provider (OpenAI requires separate paid key)
FIREAI_MEMORY_LLM_PROVIDER=gemini
FIREAI_MEMORY_LLM_MODEL=gemini-2.0-flash
FIREAI_MEMORY_EMBEDDER_PROVIDER=gemini
FIREAI_MEMORY_EMBEDDER_MODEL=models/embedding-001

# === QOMN Kernel HMAC Key ===
# HMAC key for QOMN audit chain integrity.
# Must be at least 32 bytes. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
FIREAI_QOMN_HMAC_KEY=

# === Wiki Configuration ===
FIREAI_WIKI_ROOT=

# === FireAI API ===
# SECURITY: Generate a strong random key! Do NOT use the example below.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FIREAI_API_KEY=

# === Security ===
# HMAC key for evidence package tamper-proofing.
# Must be at least 32 bytes. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
FIREAI_EVIDENCE_HMAC_KEY=
AUDIT_HMAC_KEY=

# === Deployment Environment ===
# Options: production, development
# Affects: CORS policy, rate limiting, security warnings
FIREAI_ENV=production

# === CORS ===
# Comma-separated list of allowed origins for CORS.
# Wildcards (*) are ALWAYS rejected in production.
# In production, prefer populating _PRODUCTION_TRUSTED_ORIGINS in source code.
CORS_ORIGINS=

# === Rate Limiting ===
# Default rate limit: "requests/minutes" (e.g., "120/1" = 120 per minute)
# Per-path limits are hardcoded in backend_app.py and override this for matched paths.
FIREAI_RATE_LIMIT=120/1

# === Logging ===
LOG_LEVEL=INFO
# Maximum log file size in bytes (default: 524288000 = 500 MB)
FIREAI_LOG_MAX_BYTES=524288000
# Number of rotated log file backups (default: 20)
FIREAI_LOG_BACKUP_COUNT=20
# Log retention in days for timed rotation (default: 30)
FIREAI_LOG_RETENTION_DAYS=30
# Directory for log files (default: ./logs)
FIREAI_LOG_DIR=

# === DDC Converter Security ===
# Comma-separated list of allowed directories for file uploads.
# Files outside these directories are rejected (path traversal prevention).
FIREAI_ALLOWED_UPLOAD_DIRS=/tmp,/var/tmp,/var/fireai/uploads
# Base directory for DDC subprocess working directory (cwd).
# The subprocess runs in a subdirectory of this path, NOT in the output directory.
FIREAI_DDC_CWD_BASE=

# === Database ===
DATABASE_URL=sqlite:///data/fireai.db

# === Content-Security-Policy (CSP) ===
# V119 (Finding #4): The default for CSP_UNSAFE_EVAL is now ENVIRONMENT-AWARE:
#   - FIREAI_ENV=production (default)   → unsafe-eval DISABLED (secure default)
#   - FIREAI_ENV=development            → unsafe-eval ENABLED (for Vite HMR)
# Explicit setting always overrides the default.
#
# WHEN TO ENABLE IN PRODUCTION (CSP_UNSAFE_EVAL=true):
#   Only if your frontend bundle requires runtime code generation, e.g.:
#     - Legacy chart libraries that build functions from strings
#     - Templating engines that compile templates at runtime
#   Modern recharts (≥2.x) and three.js (≥0.150) do NOT require it.
#
# SECURITY IMPACT WHEN ENABLED:
#   'unsafe-eval' significantly amplifies the impact of any XSS vulnerability.
#   In a safety-critical fire alarm engineering UI, this could allow attackers
#   to silently modify detector placements, battery sizes, or voltage drops
#   that operators then rely on for life-safety decisions.
#
# When enabled in production, _build_csp() logs at ERROR level so the risk
# cannot hide in log noise.
#
# CSP_UNSAFE_EVAL=true   # uncomment ONLY if your frontend genuinely needs it

# CSP connection sources for production. Comma-separated origins.
# In development, http://localhost:* and ws://localhost:* are auto-allowed.
# CSP_CONNECT_SRC=https://api.example.com,wss://ws.example.com
