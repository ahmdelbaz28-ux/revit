# FireAI Environment Configuration
FIREAI_ENV=development
FIREAI_API_KEY=YOUR_FIREAI_API_KEY
FIREAI_SESSION_SECRET=YOUR_SESSION_SECRET

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
DIGITAL_TWIN_DB_PATH=./db/digital_twin.db
UDM_DB_PATH=./db/udm_elements.db

# Supabase Integration
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# CORS Configuration
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Neon PostgreSQL Fallback (optional)
NEON_DATABASE_URL=postgresql://username:password@ep-xyz.region.aws.neon.tech/dbname?sslmode=require

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# NVIDIA API Configuration
NVIDIA_API_KEY=napi_...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2

# Resend API Configuration
RESEND_API_KEY=re_...

# Box Client Integration
BOX_CLIENT_ID=YOUR_BOX_CLIENT_ID
BOX_CLIENT_SECRET=YOUR_BOX_CLIENT_SECRET
BOX_DEVELOPER_TOKEN=YOUR_BOX_DEVELOPER_TOKEN
CLIENT_NAME=bazspark

# Vercel Configuration
VERCEL_DEPLOY_TOKEN=vcp_...
VERCEL_PROJECT_ID=prj_...
VERCEL_TEAM_ID=team_...

# Hugging Face Integration
HF_TOKEN=hf_...

# Daytona Integration
DAYTONA_API_TOKEN=dtn_...

# Codesandbox VPS Integration
CODESANDBOX_TOKEN=csb_v1_...

# Cloudflare User Tokens
CLOUDFLARE_USER_TOKEN_1=cfut_...
CLOUDFLARE_USER_TOKEN_2=cfut_...
CLOUDFLARE_USER_TOKEN_3=cfut_...

# GitHub repository management
GH_PAT=github_pat_...
GH_REPO=owner/repo