{
  "name": "todo-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:push": "npm run db:push --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "overrides": {
    "tar": "^7.4.0",
    "bcrypt": "^5.1.1",
    "express": "^4.21.0",
    "@types/jest": "^29.5.14",
    "node-notifier": "^10.0.1",
    "jest": "^29.7.0",
    "@jest/reporters": "^29.7.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
